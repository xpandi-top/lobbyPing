rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Buildings: read by all, write by authenticated users
    match /buildings/{buildingId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;

      // Rooms
      match /rooms/{roomId} {
        allow read: if true;
        allow create, update, delete: if request.auth != null;

        // Invite Codes
        match /inviteCodes/{codeId} {
          // Read: any auth user (needed for redemption lookup + listing)
          allow read: if request.auth != null;

          // Create: auth users (admin creates owner codes, owner creates member codes)
          allow create: if request.auth != null &&
            request.resource.data.keys().hasAll([
              'code','buildingId','roomId','role','redeemed','redeemedAt',
              'redeemedByDeviceId','createdBy','expiresAt','permissions','createdAt'
            ]) &&
            request.resource.data.redeemed == false &&
            request.resource.data.role in ['owner','member'];

          // Update: only to mark as redeemed (set redeemed=true, redeemedAt, redeemedByDeviceId)
          allow update: if request.auth != null &&
            request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['redeemed','redeemedAt','redeemedByDeviceId']) &&
            request.resource.data.redeemed == true &&
            resource.data.redeemed == false;

          // Delete: auth users (admin/owner housekeeping)
          allow delete: if request.auth != null;
        }

        // Devices: create/update by auth, no public read
        match /devices/{deviceId} {
          allow read: if request.auth != null;
          allow create: if request.auth != null;
          allow update: if request.auth != null;
          allow delete: if request.auth != null;
        }

        // Arrivals
        match /arrivals/{arrivalId} {
          allow read: if true;

          allow create: if
            request.auth != null &&
            request.resource.data.keys().hasAll([
              'buildingId','roomId','roomNumber','type','waitTime',
              'status','response','reminderCount','createdAt','expiresAt'
            ]) &&
            request.resource.data.status == 'pending' &&
            request.resource.data.response == null &&
            request.resource.data.reminderCount == 0 &&
            request.resource.data.type in ['package','food','guest','other'] &&
            request.resource.data.waitTime in ['1min','2min','5min'];

          allow update: if
            request.auth != null &&
            (
              // Reminder increment (visitor)
              (
                request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reminderCount']) &&
                request.resource.data.reminderCount <= 3 &&
                request.resource.data.reminderCount == resource.data.reminderCount + 1 &&
                resource.data.status == 'pending'
              ) ||
              // Response (resident)
              (
                request.resource.data.diff(resource.data).affectedKeys()
                  .hasOnly(['response','status','respondedByName','respondedByRole']) &&
                request.resource.data.response in ['coming_down','leave_in_lobby','no_need_to_wait'] &&
                request.resource.data.status == 'responded' &&
                resource.data.status == 'pending'
              ) ||
              // Expire (Cloud Function)
              (
                request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) &&
                request.resource.data.status == 'expired'
              )
            );

          allow delete: if request.auth != null;
        }
      }
    }

    // CollectionGroup rule for invite code lookup across all rooms
    match /{path=**}/inviteCodes/{codeId} {
      allow read: if request.auth != null;
    }
  }
}
